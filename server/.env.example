# Environment Configuration for InvPatrimonio
NODE_ENV=production

# Server Configuration
PORT=3001
FRONTEND_URL=https://patrimonio.siafsystem.online

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=invpatrimonio
DB_USER=invpatrimonio_user
|DB_PASSWORD=your_secure_db_password_here
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis Cluster Configuration
REDIS_NODES=127.0.0.1:7000,127.0.0.1:7001,127.0.0.1:7002
REDIS_PASSWORD=your_secure_redis_password_here

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_change_this_in_production_at_least_256_bits
JWT_EXPIRES_IN=24h

# Logging Configuration
LOG_LEVEL=info

# Security Configuration
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# File Upload Configuration
MAX_FILE_SIZE=50MB
UPLOAD_PATH=/var/www/invpatrimonio/uploads

# SSL Configuration (for production)
SSL_CERT_PATH=/etc/letsencrypt/live/patrimonio.siafsystem.online/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/patrimonio.siafsystem.online/privkey.pem

# Monitoring and Analytics
ENABLE_METRICS=true
METRICS_PORT=9090

# External Services (optional)
# SENTRY_DSN=your_sentry_dsn_here
# SLACK_WEBHOOK_URL=your_slack_webhook_for_alerts

# =====================================================
# INVENTARIO PATRIMONIAL - SWITCH API/BD
# =====================================================
# Modo de obtención de datos de inventario
# Valores: 'bd' (Base de Datos Local) o 'api' (API Externa UMICH)
# Por defecto: 'bd' (Base de Datos Local)
INVENTARIO_DATA_SOURCE=bd

# URL de la API externa de UMICH (solo si INVENTARIO_DATA_SOURCE=api)
UMICH_API_BASE_URL=http://10.10.0.94:3030

# Configuración de fotos
MAX_FOTOS_POR_ITEM=3
CATEGORIAS_COLAPSABLES=true

# Módulos activos
INVENTARIO_INTERNO_ACTIVO=true
INVENTARIO_EXTERNO_ACTIVO=true